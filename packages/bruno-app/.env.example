# Convex cloud URL exposed to the renderer.
# Example: https://your-deployment.convex.cloud
VITE_CONVEX_URL=

# Kept for compatibility with code paths that also read NEXT_PUBLIC_CONVEX_URL.
NEXT_PUBLIC_CONVEX_URL=

# Optional OAuth2 callback URL shown when launching auth in the system browser.
VITE_MAX_OAUTH2_CALLBACK_URL=
