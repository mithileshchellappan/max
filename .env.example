# Convex deployment used by the backend functions.
# Example: dev:your-deployment-name
CONVEX_DEPLOYMENT=

# Convex cloud URL.
# Example: https://your-deployment.convex.cloud
CONVEX_URL=

# Convex HTTP actions / auth site URL.
# Example: https://your-deployment.convex.site
CONVEX_SITE_URL=

# Optional JSON endpoint for in-app notifications.
MAX_INFO_ENDPOINT=

# Optional OAuth2 callback URL used when launching auth in the system browser.
MAX_OAUTH2_CALLBACK_URL=
